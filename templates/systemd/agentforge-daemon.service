[Unit]
Description=AgentForge PR comment daemon
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/path/to/your/repo
ExecStart=/usr/bin/env bash -lc 'source .venv/bin/activate && agentforge daemon'
Restart=always
RestartSec=5

# Security hardening (optional)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/path/to/your/repo

[Install]
WantedBy=multi-user.target
